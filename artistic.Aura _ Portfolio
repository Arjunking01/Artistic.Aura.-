@charset "utf-8";

:root { --bg: #0e0e10; --card: #1a1a1d; --accent: #ff8c00; --yellow: #ffd54f; --text: #ffffff; --grey: #b0b0b0; }

* { margin: 0px; padding: 0px; box-sizing: border-box; font-family: Poppins, sans-serif; scroll-behavior: smooth; }

body { background: var(--bg); color: var(--text); }

header { text-align: center; padding: 60px 20px; }

header h1 { font-size: 3rem; color: var(--accent); text-shadow: rgba(255, 140, 0, 0.6) 0px 0px 20px; }

.subtitle { color: var(--grey); margin-top: 10px; animation: 2s ease 0s 1 normal none running fadeIn; }

.section { padding: 50px 20px; max-width: 1100px; margin: auto; }

.card { background: var(--card); padding: 20px; margin: 15px 0px; border-radius: 15px; box-shadow: rgba(255, 140, 0, 0.2) 0px 0px 15px; transition: 0.4s; }

.card:hover { transform: translateY(-8px) scale(1.02); box-shadow: rgba(255, 140, 0, 0.6) 0px 0px 30px; }

.btn { display: inline-block; padding: 12px 22px; margin-top: 12px; background: linear-gradient(45deg,var(--accent),var(--yellow)); color: rgb(0, 0, 0); font-weight: bold; border-radius: 12px; text-decoration: none; box-shadow: rgba(255, 200, 0, 0.6) 0px 0px 10px; transition: 0.3s; }

.btn:hover { box-shadow: rgb(255, 200, 0) 0px 0px 25px; transform: scale(1.05); }

.gallery { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }

.gallery img { width: 100%; border-radius: 15px; transition: 0.4s; }

.gallery img:hover { transform: scale(1.05); box-shadow: rgba(255, 140, 0, 0.6) 0px 0px 20px; }

.whatsapp { position: fixed; bottom: 20px; right: 20px; background: rgb(37, 211, 102); color: rgb(255, 255, 255); padding: 12px 16px; border-radius: 50px; text-decoration: none; font-weight: bold; box-shadow: rgba(0, 255, 100, 0.6) 0px 0px 15px; }

@keyframes fadeIn { 
  0% { opacity: 0; transform: translateY(20px); }
  100% { opacity: 1; transform: translateY(0px); }
}

footer { text-align: center; padding: 20px; color: var(--grey); }
